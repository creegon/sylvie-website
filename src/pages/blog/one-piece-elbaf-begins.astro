    font-size: 1.8rem;
    line-height: 1.4;
    margin-bottom: 1rem;
    color: var(--text-primary, #e2e8f0);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    color: var(--text-muted, #94a3b8);
    font-size: 0.9rem;
  }

  .tag {
    background: var(--tag-bg, rgba(148, 163, 184, 0.15));
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .content {
    line-height: 1.9;
    color: var(--text-secondary, #cbd5e1);
  }

  .content p {
    margin-bottom: 1.4rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border, rgba(148, 163, 184, 0.2));
    margin: 2rem 0;
  }

  .postscript {
    font-style: italic;
    color: var(--text-muted, #94a3b8);
    font-size: 0.9rem;
  }

  .back-link {
    margin-top: 3rem;
  }

  .back-link a {
    color: var(--accent, #7c9cbf);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link a:hover {
    text-decoration: underline;
  }
</style>
